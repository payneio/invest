# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.ipynb_checkpoints/
.working/

# uv
# (uv.lock IS committed — it pins the resolved environment)

# Processed data store (regenerated by the pipeline)
data/processed/*.parquet

# Personal financial data — never commit raw broker exports
data/raw/**/*.csv
data/raw/**/*.json
# Account-number -> name map holds real account numbers
config/accounts.yaml

# Beancount ledger DATA — source of truth, holds holdings/account numbers.
# Anchored to the repo root so it ignores the /ledger/ data tree only, NOT the
# src/invest/ledger/ Python package. (You may want to version the data in a
# PRIVATE repo to track your fixups.)
/ledger/
# Robinhood auth material — bearer token / cached session, never commit
data/raw/robinhood/.rh_token
.tokens/

# Jupyter notebook execution outputs are kept, but scratch checkpoints are not
